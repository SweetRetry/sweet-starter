{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "apps/web": {
      "entry": ["app/**/*.{ts,tsx}", "components/**/*.{ts,tsx}", "hooks/**/*.{ts,tsx}"],
      "project": ["**/*.{ts,tsx}"]
    },
    "packages/ui": {
      "entry": ["src/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/typescript-config": {
      "entry": [],
      "project": ["*.json"]
    }
  },
  "ignoreDependencies": ["@types/*", "@tailwindcss/postcss"],
  "ignoreUnresolved": ["next"]
}
